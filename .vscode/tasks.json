{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🔎 Analyze PowerShell Scripts",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "Get-ChildItem -Recurse -Filter *.ps1 | ForEach-Object { Invoke-ScriptAnalyzer -Path $_.FullName }"
      ],
      "problemMatcher": [],
      "detail": "Fürt den Invoke-ScriptAnalyzer für alle PowerShell-Skripte im Projekt aus",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "🔧 Create Patch Release Tag",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "$current = (git describe --tags --abbrev=0 2>$null).TrimStart(\"v\"); if (-not $current) { $current = \"0.0.0\" }; $parts = $current -split '\\.'; $patch = [int]$parts[2] + 1; $newVersion = \"$($parts[0]).$($parts[1]).$patch\"; $tagName = \"v$newVersion\"; Write-Host \"Creating tag: $tagName\"; git tag -a \"$tagName\" -m \"Release version $newVersion\"; Write-Host \"Tag created successfully: $tagName\""
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Erstellt einen neuen Patch-Release-Tag (z.B. v1.0.0 → v1.0.1 für Bug-Fixes)"
    },
    {
      "label": "⚡ Create Minor Release Tag",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "$current = (git describe --tags --abbrev=0 2>$null).TrimStart(\"v\"); if (-not $current) { $current = \"0.0.0\" }; $parts = $current -split '\\.'; $minor = [int]$parts[1] + 1; $newVersion = \"$($parts[0]).$minor.0\"; $tagName = \"v$newVersion\"; Write-Host \"Creating tag: $tagName\"; git tag -a \"$tagName\" -m \"Release version $newVersion\"; Write-Host \"Tag created successfully: $tagName\""
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Erstellt einen neuen Minor-Release-Tag (z.B. v1.0.0 → v1.1.0 für neue Features)"
    },
    {
      "label": "🚀 Create Major Release Tag",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "$current = (git describe --tags --abbrev=0 2>$null).TrimStart(\"v\"); if (-not $current) { $current = \"0.0.0\" }; $parts = $current -split '\\.'; $major = [int]$parts[0] + 1; $newVersion = \"$major.0.0\"; $tagName = \"v$newVersion\"; Write-Host \"Creating tag: $tagName\"; git tag -a \"$tagName\" -m \"Release version $newVersion\"; Write-Host \"Tag created successfully: $tagName\""
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Erstellt einen neuen Major-Release-Tag (z.B. v1.0.0 → v2.0.0 für Breaking Changes)"
    },
    {
      "label": "📋 Show Latest Tag",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "$tag = git describe --tags --abbrev=0 2>$null; if ($tag) { Write-Host \"Latest tag: $tag\" } else { Write-Host \"No tags found\" }"
      ],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Zeigt den neuesten Git-Tag an"
    },
    {
      "label": "🚢 Push Tags to Remote",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "Write-Host \"Pushing tags to remote...\"; git push origin --tags; Write-Host \"Tags pushed successfully!\""
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Pushed alle Tags zu Remote (triggert automatisch GitHub Release Workflow)"
    },
    {
      "label": "🔄 Complete Release (Patch)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "🔧 Create Patch Release Tag",
        "🚢 Push Tags to Remote"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Vollständiger Workflow: Patch-Release-Tag erstellen → Commits stagen → zu Remote pushen → GitHub Release"
    },
    {
      "label": "🔄 Complete Release (Minor)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "⚡ Create Minor Release Tag",
        "🚢 Push Tags to Remote"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Vollständiger Workflow: Minor-Release-Tag erstellen → Commits stagen → zu Remote pushen → GitHub Release"
    },
    {
      "label": "🔄 Complete Release (Major)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "🚀 Create Major Release Tag",
        "🚢 Push Tags to Remote"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Vollständiger Workflow: Major-Release-Tag erstellen → Commits stagen → zu Remote pushen → GitHub Release"
    }
  ]
}